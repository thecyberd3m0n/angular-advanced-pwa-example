      "name": "Piotr Kasperski",
      "email": "piotr.kasperski94@gmail.com",
      "url": "https://piotrkasperski.ovh"
    }
  ],
  "scripts": {
    "ng": "ng",
    "start": "concurrently --kill-others --names \"ng,sw\" --prefix-colors \"cyan,magenta\" \"ng serve\" \"npm run build:sw:watch\"",
    "build": "ng build && npm run build:sw:prod",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build:sw": "node esbuild.sw.mjs",
    "build:sw:watch": "node esbuild.sw.mjs --watch",
    "build:sw:prod": "node esbuild.sw.mjs --prod"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/service-worker": "^21.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.3",
    "@angular/cli": "^21.0.3",
    "@angular/compiler-cli": "^21.0.0",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.0",
    "jsdom": "^27.1.0",
    "tinyglobby": "^0.2.17",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
