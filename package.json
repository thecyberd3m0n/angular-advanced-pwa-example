{
  "name": "angular-advanced-pwa-example",
  "version": "0.0.0",
  "author": "Dmitrij Rysanow <admin@dmitrijrysanow.pro> (https://dmitrijrysanow.pro)",
  "contributors": [
    {
      "name": "Dmitrij Rysanow",
